// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"

}

datasource db {
  provider = "postgresql"

}

enum Status {
  PENDING
  CANCELED
  DELIVERED
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  age       Int
  role  Role   @default(USER)

  orders FoodOrder[]
}

model Food {
    id        Int      @id @default(autoincrement())
    name String
    price String
    image       String @default("default_image.jpg")
    ingredients String @default("None")
    category FoodCategory @relation(fields:[foodCategoryId], references: [id])
    foodCategoryId Int
    foodOrderItems FoodOrderItem[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model FoodCategory {
  id        Int      @id @default(autoincrement())
  name      String
  foods     Food[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodOrder {
  id            Int      @id @default(autoincrement())
  userId        Int
  totalPrice    String
  status        Status @default(PENDING)
  foodOrderItems     FoodOrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id])
}


model FoodOrderItem {
  id          Int      @id @default(autoincrement())
  quantity    Int
  food        Food @relation(fields: [foodId], references: [id])
  foodId      Int
  order       FoodOrder @relation(fields: [foodOrderId],references: [id])
  foodOrderId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

